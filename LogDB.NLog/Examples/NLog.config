<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="logs/internal-nlog.txt">

  <!-- Load LogDB.NLog extension -->
  <extensions>
    <add assembly="LogDB.NLog" />
  </extensions>

  <!-- Define targets -->
  <targets>
    <!-- Console target for local development -->
    <target name="console" 
            xsi:type="Console" 
            layout="${longdate} ${level:uppercase=true} ${logger} ${message} ${exception:format=tostring}" />

    <!-- LogDB target -->
    <target name="logdb" 
            xsi:type="LogDB"
            apiKey="${configsetting:item=LogDB:ApiKey}"
            defaultApplication="ExampleApp"
            defaultEnvironment="${configsetting:item=ASPNETCORE_ENVIRONMENT:default=Development}"
            defaultCollection="app-logs"
            defaultPayloadType="Log"
            minimumLevel="Info"
            enableBatching="true"
            batchSize="100"
            flushIntervalSeconds="5"
            enableCompression="true"
            maxRetries="3"
            enableCircuitBreaker="true" />
  </targets>

  <!-- Define rules -->
  <rules>
    <!-- Skip non-critical Microsoft logs and so log only own logs -->
    <logger name="Microsoft.*" maxLevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxLevel="Info" final="true" />
    
    <!-- Write to both console and LogDB -->
    <logger name="*" minLevel="Info" writeTo="console,logdb" />
  </rules>
</nlog>






